# =============================================================================
# Aifficient Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in every value marked [REQUIRED].
# Values marked [OPTIONAL] have safe defaults; set them to tune behaviour.
# NEVER commit the live .env file — it contains real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
APP_NAME=Aifficient
# "development" | "staging" | "production"
ENV=production

# ---------------------------------------------------------------------------
# PostgreSQL [REQUIRED]
# ---------------------------------------------------------------------------
POSTGRES_DB=aifficient
POSTGRES_USER=aifficient
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32+CHARS
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full SQLAlchemy connection string (overrides individual vars above when set)
DATABASE_URL=postgresql+psycopg2://aifficient:CHANGE_ME_STRONG_PASSWORD_32+CHARS@localhost:5432/aifficient

# ---------------------------------------------------------------------------
# Redis [REQUIRED]
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth / JWT [REQUIRED]
# ---------------------------------------------------------------------------
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Email (SMTP) [REQUIRED for invite emails; OPTIONAL for core functionality]
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
SMTP_FROM_NAME=Aifficient
# URL shown in invite / password-reset emails
APP_LOGIN_URL=https://your-domain.com/login

# ---------------------------------------------------------------------------
# OpenAI / GPT-4o [REQUIRED for AI calling]
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.4
OPENAI_MAX_TOKENS=320
OPENAI_TIMEOUT_SECONDS=30.0
OPENAI_MAX_RETRIES=2
# Optional: set if using an Azure OpenAI proxy
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_ORG_ID=org-CHANGE_ME

# ---------------------------------------------------------------------------
# ElevenLabs TTS [REQUIRED for AI calling]
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=CHANGE_ME
# Default voice ID (can be overridden per campaign)
ELEVENLABS_VOICE_ID=CHANGE_ME
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ---------------------------------------------------------------------------
# Deepgram STT [REQUIRED for AI calling]
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=CHANGE_ME
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# ---------------------------------------------------------------------------
# LiveKit [REQUIRED for AI calling]
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
LIVEKIT_TOKEN_TTL_MINUTES=60
# SIP gateway URI (e.g. "sip.livekit.cloud" or "<region>.sip.livekit.cloud")
# Required if using LiveKit-originated outbound PSTN calls
LIVEKIT_SIP_URI=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ---------------------------------------------------------------------------
# Twilio PSTN [REQUIRED for outbound phone calls]
# ---------------------------------------------------------------------------
# Account SID (AC...) — not a secret, shown on your Twilio console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth Token — secret; used for webhook signature validation
TWILIO_AUTH_TOKEN=CHANGE_ME
# Optional: scoped API Key (preferred over auth token in production)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Public HTTPS URL where Twilio can reach your backend for webhooks
TWILIO_PUBLIC_BASE_URL=https://api.your-domain.com
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_AMD_ENABLED=true
TWILIO_AMD_ASYNC=true

# ---------------------------------------------------------------------------
# Campaign / Scheduler
# ---------------------------------------------------------------------------
# Enable real outbound calling (false = AI plan only, no real Twilio calls)
CAMPAIGN_TELEPHONY_DIALING_ENABLED=true
# Dispatcher sends HTTP to FastAPI instead of running asyncio inline in Celery
CAMPAIGN_DISPATCH_VIA_HTTP=true
# Must match the FastAPI bind address (use localhost in single-host setups)
INTERNAL_API_BASE_URL=http://localhost:8000
# Shared secret for service-to-service auth (generate with openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ---------------------------------------------------------------------------
# Celery [OPTIONAL — defaults to REDIS_URL]
# ---------------------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Rate Limiting [OPTIONAL]
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AI_REQUESTS=30
RATE_LIMIT_AI_WINDOW_SECONDS=60
RATE_LIMIT_TELEPHONY_REQUESTS=60
RATE_LIMIT_TELEPHONY_WINDOW_SECONDS=60
RATE_LIMIT_CAMPAIGN_ACTIVATE_REQUESTS=20
RATE_LIMIT_CAMPAIGN_ACTIVATE_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Voicemail Upload Storage [OPTIONAL]
# ---------------------------------------------------------------------------
VOICEMAIL_UPLOAD_DIR=uploads/voicemail
VOICEMAIL_MAX_BYTES=5242880
VOICEMAIL_ALLOWED_FORMATS=mp3,wav,x-wav,wave,ogg,mpeg,aac
VOICEMAIL_REQUIRE_PUBLIC_URL=true
VOICEMAIL_PUBLIC_ROUTE=/media/voicemail

# ---------------------------------------------------------------------------
# Logging [OPTIONAL]
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# Set to true in production for structured JSON logs (CloudWatch / Loki / Datadog)
LOG_JSON=true

# ---------------------------------------------------------------------------
# CORS [OPTIONAL — defaults to localhost dev origins only]
# ---------------------------------------------------------------------------
# In production, set this to your actual frontend domain and remove
# the allow_origin_regex=.* fallback (set ENV=production to do this automatically)
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com

# ---------------------------------------------------------------------------
# Prometheus Metrics [OPTIONAL]
# ---------------------------------------------------------------------------
# Set to "true" to enable the /metrics endpoint
ENABLE_METRICS=true
