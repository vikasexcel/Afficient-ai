# =============================================================================
# Aifficient Frontend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in every value.
# In production this file is consumed at BUILD TIME by Vite (vite build).
# Any variable exposed here is embedded into the JS bundle — never put
# secrets here.
# =============================================================================

# Backend API base URL
# - Development (Vite proxy): use relative path /api/v1
# - Production: use the full HTTPS URL of your backend API
VITE_API_URL=https://api.your-domain.com/api/v1

# Optional: public Sentry DSN for frontend error tracking (safe to expose)
# VITE_SENTRY_DSN=https://xxxx@sentry.io/yyyy

# Optional: Google Analytics measurement ID
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
